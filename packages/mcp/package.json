    "build": "tsup src/index.ts --format esm --outDir dist --dts",
    "dev": "tsup src/index.ts --format esm --outDir dist --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@promptfuel/core": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
