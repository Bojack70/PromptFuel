{
  "name": "@promptfuel/mcp",
  "version": "1.0.0",
  "description": "PromptFuel MCP server — token counting, cost estimation & prompt optimization for Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "promptfuel-mcp": "./dist/index.js"
  },
